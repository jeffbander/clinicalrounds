# ClinicalRounds Environment Variables
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# Required: Your Anthropic API key
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# ─── ParseStage (Universal Note Intake) ─────────────────────────────────
# Selects the LLM structurer used by lib/parse/ when the regex section
# detector returns medium/low confidence. Defaults to "anthropic"
# (Claude Haiku 4.5).
#
# PARSER_PROVIDER=anthropic | mistral | none
# PARSER_PROVIDER=anthropic
#
# Mistral is OFF until BAA / legal review completes. If PARSER_PROVIDER
# is set to "mistral" without MISTRAL_API_KEY, we fall back to Anthropic
# so PHI never leaves the platform unintentionally.
# MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest
